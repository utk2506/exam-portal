{
  "name": "@exam-platform/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/apps/api/src/index.js",
    "test": "node ../../node_modules/typescript/bin/tsc -p ../../packages/shared/tsconfig.json && node ../../node_modules/typescript/bin/tsc -p tsconfig.build.json && node scripts/run-tests.mjs",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@exam-platform/shared": "1.0.0",
